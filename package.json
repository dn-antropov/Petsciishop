{
  "name": "petsciishop",
  "version": "0.1",
  "description": "Petsciishop - a web-based C64 PETSCII graphics editor",
  "private": false,
  "author": "rcoenen <rcoenen@users.noreply.github.com>",
  "license": "MIT",
  "keywords": [
    "Graphics"
  ],
  "overrides": {
    "c64jasm": {
      "chokidar": "^3.6.0"
    }
  },
  "scripts": {
    "build:truskii-wasm": "node scripts/buildTruskiiWasm.mjs",
    "predev": "npm run build:truskii-wasm",
    "prebuild": "npm run build:truskii-wasm",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "truski:harness:record": "node scripts/truski3000-harness/run.mjs record",
    "truski:harness:compare": "node scripts/truski3000-harness/run.mjs compare",
    "truski:harness:compare:mcm": "node scripts/truski3000-harness/run.mjs compare --mode mcm",
    "truski:harness:benchmark": "node scripts/truski3000-harness/run.mjs benchmark",
    "truski:harness:benchmark:mcm": "node scripts/truski3000-harness/run.mjs benchmark --mode mcm --preset true-neutral --acceleration auto",
    "truski:harness:parity": "node scripts/truski3000-harness/run.mjs parity",
    "truski:harness:parity:mcm": "node scripts/truski3000-harness/run.mjs parity --mode mcm --max-ms 300000",
    "truski:harness:validate": "node scripts/truski3000-harness/run.mjs validate"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "c1541": "^0.1.0",
    "c64jasm": "^0.8.1",
    "classnames": "^2.2.6",
    "fast-memoize": "^2.5.1",
    "fflate": "^0.8.2",
    "gifenc": "^1.0.1",
    "invariant": "^2.2.4",
    "path-browserify": "^1.0.1",
    "prop-types": "^15.8.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-redux": "^8.0.0",
    "redux": "^4.0.1",
    "redux-logger": "^3.0.6",
    "redux-thunk": "^2.3.0",
    "redux-undo": "^1.1.0"
  },
  "devDependencies": {
    "@types/classnames": "^2.2.6",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/react-redux": "^7.1.25",
    "@types/resize-observer-browser": "^0.1.5",
    "@vitejs/plugin-react": "^4.0.0",
    "assemblyscript": "^0.28.9",
    "playwright": "^1.58.2",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ]
}
